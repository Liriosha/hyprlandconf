sort=-time
layer=overlay
background-color=#333333FF
width=300
height=110
border-size=2
border-color=#9c2fe0
border-radius=0
icons=1
max-icon-size=64
default-timeout=5000
ignore-timeout=0
progress-color=#9c2fe0
font=JetBrainsMono Nerd Font 10

[urgency=low]
border-color=#cccccc

[urgency=normal]
border-color=#d08770

[urgency=high]
border-color=#bf616a
default-timeout=0

[category=mpd]
default-timeout=2000
group-by=category

# Used for things such as volume or brightness
# Usually meters, hence the name
# Displayed in the top-center below the waybar
[category=system-meter]
anchor=top-center
border-color=#9c2fe0
default-timeout=800
